---
import ToolLayout from '../layouts/ToolLayout.astro';
---

<ToolLayout title="404 — không tìm thấy trang | bodev.vn" description="Trang bạn tìm không tồn tại.">
  <div class="mx-auto flex min-h-[62vh] max-w-xl flex-col items-center justify-center px-4 text-center">
    <p class="font-mono text-7xl font-bold tracking-tight text-ink">404</p>
    <p class="mt-4 max-w-md font-mono text-xs leading-relaxed text-muted">
      <span class="text-accent-ink">$</span> git checkout trang-nay
      <br />
      error: pathspec 'trang-nay' did not match any file(s) known to git
    </p>
    <h1 class="mt-5 font-serif text-2xl font-semibold text-ink">Trang này chưa được commit 🤷</h1>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <a
        href="/"
        class="inline-flex items-center gap-1.5 rounded-lg bg-ink px-4 py-2 font-mono text-sm text-surface transition-opacity hover:opacity-90"
      >
        ← về feed
      </a>
      <a
        href="/thai-ky"
        class="inline-flex items-center gap-1.5 rounded-lg border border-hair/15 px-4 py-2 font-mono text-sm text-ink transition-colors hover:bg-hair/[0.03]"
      >
        thai kỳ
      </a>
      <a
        href="/cong-dong"
        class="inline-flex items-center gap-1.5 rounded-lg border border-hair/15 px-4 py-2 font-mono text-sm text-ink transition-colors hover:bg-hair/[0.03]"
      >
        khám phá
      </a>
    </div>
  </div>
</ToolLayout>
